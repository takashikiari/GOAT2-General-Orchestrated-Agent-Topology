# Copy this file to .env and fill in real values. Never commit .env.
#
# Model and per-role behaviour is configured in config/agents.toml (non-secret).
# Only secrets and infrastructure endpoints belong here.

# ── Required ──────────────────────────────────────────────────────────────────

# API key for your LLM provider — variable name follows the pattern:
# GOAT_{PROVIDER}_API_KEY  where provider is: openai | deepseek | groq
# Add one line per provider you use.
# GOAT_OPENAI_API_KEY=
# GOAT_DEEPSEEK_API_KEY=
# GOAT_GROQ_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ── Optional overrides ────────────────────────────────────────────────────────

# TIMEOUT_SECONDS=30
# MAX_TOKENS=2048

# DAG sandbox workspace directory
# DAG_WORKSPACE=/path/to/dag_workspace

# Suppress HuggingFace unauthenticated requests warning (no token needed)
# HF_HUB_DISABLE_WARNINGS=1
