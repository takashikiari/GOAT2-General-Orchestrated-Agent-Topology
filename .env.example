# Copy this file to .env and fill in real values. Never commit .env.
#
# Model and per-role behaviour is configured in config/agents.toml (non-secret).
# Only secrets and infrastructure endpoints belong here.

# ── Required ──────────────────────────────────────────────────────────────────

# LLM provider API key
DEEPSEEK_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ── LLM connection (optional — defaults match config/agents.toml) ─────────────

# MODEL_NAME=deepseek-v4-flash
# BASE_URL=https://api.deepseek.com
# MAX_TOKENS=2048
# TIMEOUT_SECONDS=30.0
# TEMPERATURE=0.5

# ── Per-role overrides (optional — set in config/agents.toml instead) ─────────
# Use env vars for emergency runtime overrides without editing TOML.

# GOAT_AGENT_PLANNER_MODEL=
# GOAT_AGENT_PLANNER_PROVIDER=          # openai | deepseek | groq
# GOAT_AGENT_PLANNER_TEMPERATURE=
# GOAT_AGENT_PLANNER_TOOL_CALLING=      # true | false

# GOAT_AGENT_RESEARCHER_MODEL=
# GOAT_AGENT_RESEARCHER_PROVIDER=
# GOAT_AGENT_RESEARCHER_TEMPERATURE=
# GOAT_AGENT_RESEARCHER_TOOL_CALLING=

# GOAT_AGENT_CODER_MODEL=
# GOAT_AGENT_CODER_PROVIDER=
# GOAT_AGENT_CODER_TEMPERATURE=

# GOAT_AGENT_CRITIC_MODEL=
# GOAT_AGENT_CRITIC_PROVIDER=
# GOAT_AGENT_CRITIC_TEMPERATURE=

# GOAT_AGENT_SUMMARIZER_MODEL=
# GOAT_AGENT_SUMMARIZER_PROVIDER=
# GOAT_AGENT_SUMMARIZER_TEMPERATURE=

# GOAT_AGENT_TOOL_CALLER_MODEL=
# GOAT_AGENT_TOOL_CALLER_PROVIDER=
# GOAT_AGENT_TOOL_CALLER_TEMPERATURE=
# GOAT_AGENT_TOOL_CALLER_TOOL_CALLING=

# GOAT_AGENT_MEMORY_MODEL=
# GOAT_AGENT_MEMORY_PROVIDER=
# GOAT_AGENT_MEMORY_TEMPERATURE=

# ── Infrastructure (optional) ─────────────────────────────────────────────────

# DAG sandbox workspace directory
# DAG_WORKSPACE=/path/to/dag_workspace
