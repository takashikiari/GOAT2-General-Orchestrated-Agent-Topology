# Copy this file to .env and fill in real values. Never commit .env.
#
# Model and per-role behaviour is configured in config/agents.toml (non-secret).
# Only secrets and infrastructure endpoints belong here.

# ── Required ──────────────────────────────────────────────────────────────────

# API keys — only set the keys for providers you actually use
DEEPSEEK_API_KEY=
GOAT_GROQ_API_KEY=
# GOAT_OPENAI_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ── Optional overrides ────────────────────────────────────────────────────────

# TIMEOUT_SECONDS=30
# MAX_TOKENS=2048

# DAG sandbox workspace directory
# DAG_WORKSPACE=/path/to/dag_workspace
