# GOAT 2.0 — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env in the project root and fill in your values.
# Never commit .env to git — it contains your private keys.
#
# How to copy:
#   cp setup/templates/.env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram (required) ───────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram to get this token.
TELEGRAM_TOKEN=

# ── LLM Providers ─────────────────────────────────────────────────────────────
# Add only the providers you want to use. Leave others blank or remove them.

DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ── Services ──────────────────────────────────────────────────────────────────
# Override defaults from goat2.toml if needed.

# Redis — leave blank to use the default (redis://localhost:6379/0)
REDIS_URL=

# Letta — only needed if services.letta.enabled = true in goat2.toml
# LETTA_URL=http://localhost:8283
