"""GOAT 2.0 Telegram interface — one message = one intent.

Tool calls are executed internally by _call_with_tools() and never exposed
as separate Telegram messages. The bot only responds with result.summary.
"""
from __future__ import annotations

import asyncio
import logging
import os
import re
from typing import Final

from telegram import Update
from telegram.ext import Application, MessageHandler, filters, ContextTypes

from config.registry import ServiceRegistry
from config.toml_loader import load_toml
from supervisor.supervisor import GoatSupervisor
from supervisor.interfaces.content_filter import mask_sensitive

log = logging.getLogger("goat2.supervisor.interfaces")

_TOKEN: Final[str] = os.environ.get("TELEGRAM_TOKEN") or load_toml().channel_str("telegram_token")

# Global ServiceRegistry for all sessions
_registry = ServiceRegistry()

# Set global registry for tool handlers
from tools.registry_accessor import set_registry
set_registry(_registry)

# Per-chat supervisor — each chat keeps its own conversation history.
_sessions: dict[int, GoatSupervisor] = {}


def _supervisor_for(chat_id: int) -> GoatSupervisor:
    """Return the per-chat GoatSupervisor, creating it on first use."""
    if chat_id not in _sessions:
        _sessions[chat_id] = GoatSupervisor(registry=_registry)
    return _sessions[chat_id]


def _clean_dsml_tags(text: str) -> str:
    """Strip DSML tags (invoke, tool_calls, etc.) from text."""
    if not text:
        return ""
    # Remove DSML blocks with different opening/closing tags
    clean = re.sub(r'<\｜｜DSML｜｜[^>]*>.*?</\｜｜DSML｜｜[^>]*>', '', text, flags=re.DOTALL)
    # Remove mixed pairs
    clean = re.sub(r'<\｜｜DSML｜｜\w+>[^<]*</\｜｜DSML｜｜\w+>', '', clean, flags=re.DOTALL)
    # Remove orphaned tags
    clean = re.sub(r'</? \｜｜DSML｜｜[^>]*>', '', clean)
    clean = re.sub(r"/DSML[A-Za-z_]*", "", clean).strip()
    # If everything was stripped, try harder: remove angle-bracket noise
    if not clean:
        clean = re.sub(r"[<｜>]+", "", text).strip()
    return clean


def _has_tool_calls(text: str) -> bool:
    """Check if text contains DSML tool call tags."""
    return bool(re.search(r'<\｜｜DSML｜｜invoke>', text) or re.search(r'<\｜｜DSML｜｜tool_calls>', text))


async def _handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Route incoming text to GoatSupervisor and reply with the result summary.

    Tool calls are executed internally in a loop — GOAT can make multiple
    tool call rounds without waiting for user input between them. Only the
    final text response (with no tool calls) is sent to the chat.
    """
    # ── Ignore messages without text ──
    if not update.message or not update.message.text:
        log.debug("Ignoring non-text update type=%s", type(update.message).__name__)
        return

    intent = update.message.text.strip()
    if not intent:
        return

    chat_id = update.message.chat_id
    sv = _supervisor_for(chat_id)

    log.debug("chat=%d processing intent=%.80s", chat_id, intent)

    try:
        result = await sv.run(intent)
        raw_text = str(result.summary or "").strip()

        # ── Internal tool call loop ──
        # If the response contains tool calls, execute them and re-enter GOAT
        # with the results, without sending anything to the chat.
        max_rounds = 10  # safety limit
        for _ in range(max_rounds):
            if not _has_tool_calls(raw_text):
                break
            # Feed the response back as if it were user input
            result = await sv.run(raw_text)
            raw_text = str(result.summary or "").strip()

        # ── Final response ──
        text = mask_sensitive(raw_text)
        if not text:
            text = "..."

        clean_text = _clean_dsml_tags(text)
        if not clean_text or clean_text.strip() == "":
            clean_text = "..."

        # Telegram message limit: 4096 characters
        MAX_TELEGRAM_LEN = 4096
        if len(clean_text) > MAX_TELEGRAM_LEN:
            clean_text = clean_text[:MAX_TELEGRAM_LEN - 3] + "..."

        await update.message.reply_text(clean_text)

    except Exception as exc:
        import traceback
        log.error("chat=%d error: %s\n%s", chat_id, exc, traceback.format_exc())
        try:
            await update.message.reply_text("...")
        except Exception:
            pass


def _build_app() -> Application:
    """Build and return the Telegram Application (no polling started)."""
    app = Application.builder().token(_TOKEN).build()
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, _handle_message))
    return app


def run_polling() -> None:
    """Start polling (blocking)."""
    app = _build_app()
    log.info("Starting polling for Telegram bot ...")
    app.run_polling(allowed_updates=Update.ALL_TYPES)


async def run_webhook(
    app: Application,
    webhook_url: str,
    webhook_port: int,
    secret_token: str | None = None,
) -> None:
    """Set up webhook (non-blocking, requires running Application)."""
    log.info("Setting webhook to %s (port %d)", webhook_url, webhook_port)
    await app.bot.set_webhook(
        url=webhook_url,
        secret_token=secret_token,
        allowed_updates=Update.ALL_TYPES,
    )
    log.info("Webhook set successfully")
